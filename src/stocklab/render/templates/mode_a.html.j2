{% extends "base.html.j2" %}
{% block content %}

<div class="header">
  <div class="header-top">
    <div class="ticker-block">
      <div class="ticker-row">
        <div class="ticker-badge">{{ ticker }}</div>
        <div class="company-name">{{ display_name }}</div>
      </div>
      <div class="company-sub">{{ company_sub }}</div>
    </div>
    <div class="price-block">
      <div class="current-price">{{ price_symbol }}{% if price %}{{ "{:,.2f}".format(price) if currency != "KRW" else "{:,.0f}".format(price) }}{% else %}N/A{% endif %}</div>
      {% if krw_price_str %}<div style="font-family:var(--mono);font-size:13px;color:var(--text2);">≈ {{ krw_price_str }}</div>{% endif %}
      {% if change_pct is not none %}
      <div class="change-badge {{ 'pos' if change_pct >= 0 else 'neg' }}">{{ change_str }}</div>
      {% endif %}
    </div>
  </div>
  <div class="header-meta">
    <div class="meta-item"><span class="meta-label">시가총액</span><span class="meta-value">{{ market_cap_str }}</span></div>
    <div class="meta-item"><span class="meta-label">52주 고가</span><span class="meta-value">{{ week52_high_str }}</span></div>
    <div class="meta-item"><span class="meta-label">52주 저가</span><span class="meta-value">{{ week52_low_str }}</span></div>
    <div class="meta-item"><span class="meta-label">Forward P/E</span><span class="meta-value">{{ pe_forward_str }}</span></div>
    <div class="meta-item"><span class="meta-label">P/S (TTM)</span><span class="meta-value">{{ ps_ttm_str }}</span></div>
    <div class="meta-item"><span class="meta-label">배당수익률</span><span class="meta-value">{{ div_yield_str }}</span></div>
    <div class="meta-item"><span class="meta-label">다음 실적</span><span class="meta-value">{{ next_earnings_str }}</span></div>
    <div class="meta-item"><span class="meta-label">애널 컨센서스</span><span class="meta-value">{{ consensus_str }}</span></div>
  </div>
</div>

<div class="main">

  <!-- ② 차트 분석 영역 -->
  <div class="section-title">차트 분석 · 기술적 지표 {% if ohlc_estimated %}<span style="color:var(--text3);font-size:9px;">(est.)</span>{% endif %}</div>
  <div class="chart-area">
    <div class="volume-bar-panel">
      {% for vp in chart.volume_profile %}
      <div class="vp-row">
        <span class="vp-label">{% if currency == "KRW" %}₩{{ "{:,.0f}".format(vp.mid) }}{% else %}${{ "{:,.0f}".format(vp.mid) }}{% endif %}</span>
        <div class="vp-bar {{ vp.zone }}" style="width: {{ (vp.pct * 100 * 2) | round(0) }}%; max-width: 22px;"></div>
      </div>
      {% endfor %}
    </div>
    <div class="main-chart-wrap"><canvas id="candleChart"></canvas></div>
    <div class="indicator-panel">
      <div class="ind-block">
        <div class="ind-title">RSI(14)</div>
        <div class="ind-val {{ indicator_panel.rsi.color }}">{{ indicator_panel.rsi.value }}</div>
        <div class="ind-line">{{ indicator_panel.rsi.signal }}</div>
        <div class="ind-desc">{{ indicator_panel.rsi.desc }}</div>
      </div>
      <div class="ind-block">
        <div class="ind-title">MACD(12,26,9)</div>
        <div class="ind-val {{ 'green' if indicator_panel.macd.macd_pos else 'red' }}">{{ indicator_panel.macd.macd }}</div>
        <div class="ind-line">Signal {{ indicator_panel.macd.signal }} / Hist {{ indicator_panel.macd.hist }}</div>
        <div class="ind-desc">{{ indicator_panel.macd.desc }}</div>
      </div>
      <div class="ind-block">
        <div class="ind-title">EMA</div>
        <div class="ema-row"><span class="label ema5-c">5</span><span>{{ indicator_panel.ema.ema5 }}</span></div>
        <div class="ema-row"><span class="label ema20-c">20</span><span>{{ indicator_panel.ema.ema20 }}</span></div>
        <div class="ema-row"><span class="label ema60-c">60</span><span>{{ indicator_panel.ema.ema60 }}</span></div>
        <div class="ema-row"><span class="label ema120-c">120</span><span>{{ indicator_panel.ema.ema120 }}</span></div>
        <div class="ind-desc">{{ indicator_panel.ema.desc }}</div>
      </div>
    </div>
  </div>

  <!-- ③ 보조지표 차트 -->
  <div class="sub-charts">
    <div class="sub-chart"><canvas id="rsiChart"></canvas></div>
    <div class="sub-chart"><canvas id="macdChart"></canvas></div>
  </div>

  <!-- ④ 재무 지표 -->
  <div class="section-title">재무 지표 · TTM</div>
  <div class="fin-grid">
    {% for f in fin_cards %}
    <div class="fin-card {{ f.direction }}">
      <div class="fin-icon">{{ f.icon }}</div>
      <div class="fin-label">{{ f.label }}</div>
      <div class="fin-value">{{ f.value }}</div>
      {% if f.yoy %}<div class="fin-yoy {{ f.direction }}">YoY {{ f.yoy }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>

  <!-- ④-2 퀄리티 & 밸류에이션 -->
  <div class="section-title">퀄리티 & 밸류에이션</div>
  <div class="fin-grid">
    <div class="fin-card neutral"><div class="fin-icon">💵</div><div class="fin-label">FCF</div><div class="fin-value">{{ quality.fcf_str }}</div></div>
    <div class="fin-card {{ quality.roe_class }}"><div class="fin-icon">📊</div><div class="fin-label">ROE</div><div class="fin-value">{{ quality.roe_str }}</div></div>
    <div class="fin-card neutral"><div class="fin-icon">🏦</div><div class="fin-label">ROA</div><div class="fin-value">{{ quality.roa_str }}</div></div>
    <div class="fin-card {{ quality.peg_class }}"><div class="fin-icon">⚖️</div><div class="fin-label">PEG</div><div class="fin-value">{{ quality.peg_str }}</div></div>
    <div class="fin-card neutral"><div class="fin-icon">📈</div><div class="fin-label">EV/EBITDA</div><div class="fin-value">{{ quality.ev_ebitda_str }}</div></div>
  </div>

  <!-- ④-3 애널리스트 컨센서스 -->
  {% if analyst_box.n_analysts %}
  <div class="section-title">애널리스트 컨센서스 · {{ analyst_box.n_analysts }}명</div>
  <div class="industry-grid">
    <div class="card">
      <div class="card-title">12개월 목표가</div>
      <div style="display:flex;justify-content:space-between;align-items:baseline;gap:16px;flex-wrap:wrap;">
        <div>
          <div style="font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;">평균</div>
          <div style="font-family:var(--mono);font-size:22px;font-weight:600;color:var(--accent);">{{ analyst_box.mean_str }}</div>
          <div style="font-family:var(--mono);font-size:13px;color:var(--{{ 'green' if analyst_box.upside_class == 'up' else 'red' }});">{{ analyst_box.upside_str }}</div>
        </div>
        <div>
          <div style="font-family:var(--mono);font-size:9px;color:var(--text3);">최고</div>
          <div style="font-family:var(--mono);font-size:14px;color:var(--green);">{{ analyst_box.high_str }}</div>
          <div style="font-family:var(--mono);font-size:9px;color:var(--text3);margin-top:6px;">최저</div>
          <div style="font-family:var(--mono);font-size:14px;color:var(--red);">{{ analyst_box.low_str }}</div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-title">투자의견</div>
      <div style="font-family:var(--mono);font-size:22px;font-weight:600;color:var(--accent2);">{{ analyst_box.rec_label }}</div>
      {% if analyst_box.rec_mean %}<div style="font-family:var(--mono);font-size:11px;color:var(--text3);margin-top:4px;">Score {{ "%.2f"|format(analyst_box.rec_mean) }} / 5.00 (1=강력매수)</div>{% endif %}
    </div>
  </div>
  {% endif %}

  <!-- ④-4 시장 컨텍스트 -->
  <div class="section-title">시장 컨텍스트</div>
  <div class="fin-grid">
    <div class="fin-card {{ market_ctx.beta_class }}"><div class="fin-icon">📐</div><div class="fin-label">베타</div><div class="fin-value">{{ market_ctx.beta_str }}</div></div>
    <div class="fin-card neutral"><div class="fin-icon">🏢</div><div class="fin-label">기관보유</div><div class="fin-value">{{ market_ctx.inst_str }}</div></div>
    <div class="fin-card neutral"><div class="fin-icon">👤</div><div class="fin-label">내부자</div><div class="fin-value">{{ market_ctx.insider_str }}</div></div>
    <div class="fin-card neutral"><div class="fin-icon">📉</div><div class="fin-label">공매도%</div><div class="fin-value">{{ market_ctx.short_str }}</div></div>
    <div class="fin-card neutral"><div class="fin-icon">⏳</div><div class="fin-label">숏 회전</div><div class="fin-value">{{ market_ctx.short_ratio_str }}</div></div>
  </div>

  <!-- ④-5 단타 지표 -->
  <div class="section-title">단타 지표 · Day Trading</div>
  <div class="fin-grid">
    <div class="fin-card neutral"><div class="fin-icon">📍</div><div class="fin-label">52주 위치</div><div class="fin-value">{{ trading_box.pos_52w_pct }}</div><div class="fin-yoy" style="color:var(--text3);">고가까지 {{ trading_box.near_high_str }}</div></div>
    <div class="fin-card {{ trading_box.atr_class }}"><div class="fin-icon">📊</div><div class="fin-label">ATR(14)</div><div class="fin-value">{{ trading_box.atr_str }}</div><div class="fin-yoy" style="color:var(--text3);">일일 변동성</div></div>
    <div class="fin-card {{ trading_box.vol_spike_class }}"><div class="fin-icon">🔥</div><div class="fin-label">거래량</div><div class="fin-value">{{ trading_box.vol_spike_str }}</div><div class="fin-yoy" style="color:var(--text3);">20일 평균 대비</div></div>
    <div class="fin-card {{ trading_box.daily_rsi_class }}"><div class="fin-icon">⚡</div><div class="fin-label">일봉 RSI</div><div class="fin-value">{{ trading_box.daily_rsi_str }}</div></div>
    <div class="fin-card {{ trading_box.squeeze_class }}"><div class="fin-icon">🚀</div><div class="fin-label">숏 스퀴즈</div><div class="fin-value">{{ trading_box.squeeze_str }}</div><div class="fin-yoy" style="color:var(--text3);">short% × days</div></div>
  </div>
  <div class="card" style="margin-bottom:20px;">
    <div class="card-title">이동평균 (일봉)</div>
    <div style="display:flex;gap:24px;flex-wrap:wrap;font-family:var(--mono);font-size:12px;">
      <div><span style="color:var(--text3);">MA5:</span> <span style="color:#ff6b9d;">{{ trading_box.ma5_str }}</span></div>
      <div><span style="color:var(--text3);">MA20:</span> <span style="color:#ffd93d;">{{ trading_box.ma20_str }}</span></div>
      <div><span style="color:var(--text3);">MA50:</span> <span style="color:#6bcb77;">{{ trading_box.ma50_str }}</span></div>
      <div><span style="color:var(--text3);">MA200:</span> <span style="color:#4d96ff;">{{ trading_box.ma200_str }}</span></div>
    </div>
    <div style="margin-top:8px;font-size:12px;color:var(--accent);">{{ trading_box.trend_label }}</div>
  </div>

  <!-- ④-6 EPS 서프라이즈 -->
  {% if eps_surprises %}
  <div class="section-title">EPS 서프라이즈 · 최근 분기</div>
  <table class="strategy-table">
    <thead><tr><th>분기</th><th>Actual</th><th>Estimate</th><th>Surprise</th><th>결과</th></tr></thead>
    <tbody>
      {% for e in eps_surprises %}
      <tr>
        <td>{{ e.quarter }}</td>
        <td>{{ e.actual }}</td>
        <td>{{ e.estimate }}</td>
        <td style="color:var(--{{ 'green' if e.beat else 'red' }});">{{ e.surprise_str }}</td>
        <td><span class="badge badge-{{ 'buy' if e.beat else 'stop' }}">{{ 'BEAT' if e.beat else 'MISS' }}</span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <!-- ⑤ 매매 전략 -->
  <div class="section-title">매매 전략 · 분할 매수 가이드</div>
  <table class="strategy-table">
    <thead>
      <tr>
        <th>구분</th><th>가격 범위</th><th>비중</th><th>행동</th><th>근거</th><th>조건</th>
      </tr>
    </thead>
    <tbody>
      {% for r in strategy_rows %}
      <tr>
        <td><span class="badge badge-{{ r.badge }}">{{ r.label }}</span></td>
        <td>{{ r.price_range }}</td>
        <td>{{ r.weight }}</td>
        <td>{{ r.action }}</td>
        <td>{{ r.rationale }}</td>
        <td>{{ r.condition }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <!-- ⑥ 시나리오 분석 -->
  <div class="section-title">시나리오 분석 · 확률 가중</div>
  <div class="scenario-grid">
    {% for s in scenarios %}
    <div class="scenario-card {{ s.kind }}">
      <div class="scenario-header">
        <span class="scenario-label">{{ s.emoji }} {{ s.title }}</span>
        <span class="scenario-prob">{{ s.probability }}%</span>
      </div>
      <div class="scenario-price">{{ s.target_range }}</div>
      {% for b in s.bullets %}<div class="scenario-item">{{ b }}</div>{% endfor %}
      <div class="scenario-check">
        <div class="check-title">확인 포인트</div>
        {% for c in s.checks %}<div class="check-item">{{ c }}</div>{% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- ⑦ 산업 분석 -->
  <div class="section-title">산업 분석 · 동종업계 비교</div>
  <div class="industry-grid">
    <div class="card">
      <div class="card-title">동종업계 비교</div>
      {% if industry_rows %}
      <table class="strategy-table" style="margin: 0;">
        <thead><tr><th>종목</th><th>특화</th><th>P/S</th><th>매출 성장</th></tr></thead>
        <tbody>
          {% for r in industry_rows %}
          <tr><td{% if r.is_target %} style="color: var(--accent);"{% endif %}>{% if r.is_target %}★ {% endif %}{{ r.ticker }}</td><td>{{ r.specialty }}</td><td>{{ r.ps }}</td><td>{{ r.revenue_growth }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div style="font-size: 11px; color: var(--text3);">동종업계 데이터는 다음 단계에서 확장 예정 (Step 7).</div>
      {% endif %}
    </div>
    <div class="card">
      <div class="card-title">모멘텀 / 리스크 / 중립</div>
      <div class="tag-group">
        <div class="tag-group-title">✅ 성장 모멘텀</div>
        {% for t in industry_tags.positive %}<span class="industry-tag tag-pos">{{ t }}</span>{% endfor %}
      </div>
      <div class="tag-group">
        <div class="tag-group-title">⚠️ 주요 리스크</div>
        {% for t in industry_tags.negative %}<span class="industry-tag tag-neg">{{ t }}</span>{% endfor %}
      </div>
      <div class="tag-group">
        <div class="tag-group-title">🟡 중립 요인</div>
        {% for t in industry_tags.neutral %}<span class="industry-tag tag-neu">{{ t }}</span>{% endfor %}
      </div>
    </div>
  </div>

  <!-- ⑧ 핵심 요약 + 결론 -->
  <div class="section-title">핵심 요약 · 결론</div>
  <div class="summary-grid">
    <div class="summary-card">
      <div class="summary-title">📌 투자 핵심 포인트</div>
      {% for p in summary_points %}
      <div class="summary-point">
        <span class="num">{{ p.num }}</span>
        <span class="body"><strong>{{ p.title }}</strong> — {{ p.body }}</span>
      </div>
      {% endfor %}
    </div>
    <div class="summary-card">
      <div class="summary-title">⚡ 리스크 & 결론</div>
      {% for r in risks %}
      <div class="summary-point risk">
        <span class="num">{{ r.num }}</span>
        <span class="body"><strong>{{ r.title }}</strong> — {{ r.body }}</span>
      </div>
      {% endfor %}
      <div class="verdict-box">
        <div class="verdict-label">최종 판단</div>
        <div class="verdict-text">{{ verdict.label }}</div>
        <div class="verdict-sub">{{ verdict.sub }}</div>
      </div>
    </div>
  </div>

</div>

<div class="footer">
  {{ ticker }} · {{ display_name }} 분석 리포트 | 생성일: {{ generated_at }} | 본 자료는 투자 참고용이며 투자 손익에 대한 책임은 투자자 본인에게 있습니다.
  <br>출처: {{ sources | join(' · ') }}
</div>

{% endblock %}

{% block scripts %}
<script>
{% include "_candle.js.j2" %}
</script>
{% endblock %}
